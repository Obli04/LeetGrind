{
  "name": "leetgrind",
  "version": "0.1.2",
  "description": "Open-source Electron desktop app for LeetCode.",
  "main": "dist-electron/main.js",
  "author": "",
  "scripts": {
    "dev": "vite --host",
    "build": "vite build && electron-builder",
    "build:vite": "vite build",
    "build:electron": "vite build",
    "build:all": "npm run build:electron && vite build",
    "preview": "vite preview",
    "electron:dev": "npm run build:electron && concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0"
  },
  "dependencies": {
    "@apollo/client": "^3.8.8",
    "axios": "^1.6.2",
    "electron-store": "^8.1.0",
    "graphql": "^16.8.1",
    "leetcode-query": "^2.0.1",
    "lucide-react": "^0.294.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.21.0",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "vite-plugin-electron": "^0.15.5",
    "vite-plugin-electron-renderer": "^0.14.5",
    "wait-on": "^7.2.0",
    "esbuild": "^0.19.0"
  },
  "build": {
    "appId": "com.leetgui.app",
    "productName": "LeetGrind",
    "icon": "public/LeetGrind.png",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist",
      "dist-electron"
    ],
    "extraResources": [
      {
        "from": "public/LeetGrind.png",
        "to": "LeetGrind.png"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  }
}
